# Flask Configuration
PORT=5000
FLASK_ENV=development

# Firebase Realtime Database
# Replace this with your actual Firebase Database URL
# e.g., https://tejasvin-12345-default-rtdb.firebaseio.com/
FIREBASE_DATABASE_URL=https://tejasvin-227ee-default-rtdb.firebaseio.com/

# Option A: Path to your downloaded service account JSON file (for local development)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Option B: For Render deployment, paste the raw JSON string here
FIREBASE_CREDENTIALS_JSON=
